# Postgres connection string. Use Vercel Postgres / Neon / Supabase.
# Use the pooled URL on Vercel; direct URL only needed for migrations.
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# OpenRouter API key (recommended). Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Optional OpenRouter headers for ranking/analytics in your OpenRouter dashboard.
OPENROUTER_HTTP_REFERER="https://your-app.vercel.app"
OPENROUTER_APP_NAME="AI Chinese Writing Coach"

# Optional fallback: Anthropic direct API key. Used only if OPENROUTER_API_KEY is empty.
ANTHROPIC_API_KEY=""

# Optional: model overrides
ANALYSIS_MODEL="google/gemini-2.5-flash"
COACH_MODEL="anthropic/claude-3.5-haiku"
