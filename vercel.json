{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "functions": {
    "src/app/api/ocr/route.ts": { "maxDuration": 300 },
    "src/app/api/submissions/route.ts": { "maxDuration": 300 },
    "src/app/api/submissions/[id]/route.ts": { "maxDuration": 60 }
  }
}
